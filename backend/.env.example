# Application Configuration
# Copy this file to .env and fill in your values

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Google OAuth2 (for Gmail)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Backend
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

# Email Settings
EST_TIMEZONE=America/New_York
SEND_WINDOW_START=9  # 9 AM EST
SEND_WINDOW_END=17   # 5 PM EST
SKIP_WEEKENDS=true

# Rate Limits
MAX_EMAILS_PER_DAY=12
MAX_EMAILS_PER_HOUR=3
MIN_DELAY_BETWEEN_EMAILS=600  # 10 minutes in seconds
RANDOM_DELAY_RANGE=300  # 0-5 minutes additional jitter
OCCASIONAL_PAUSE_AFTER_EMAILS=3
OCCASIONAL_PAUSE_DURATION=1800  # 30 minutes

# Follow-up Timing (days)
FOLLOWUP1_DAYS=3
FOLLOWUP2_DAYS=6
